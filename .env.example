# ContextSuite Environment Variables
# Copy this file to .env and fill in your values

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Qdrant Cloud ---
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=contextsuite

# --- Neo4j Aura ---
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=your-neo4j-username
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=your-database-id

# --- Google / Gemini ---
GOOGLE_API_KEY=your-google-api-key
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2-preview

# --- Context Agent ---
CONTEXT_AGENT_HOST=0.0.0.0
CONTEXT_AGENT_PORT=8000

# --- CLI Agent (Local Client) ---
CLI_AGENT_HOST=127.0.0.1
CLI_AGENT_PORT=8001

# --- A2A ---
A2A_SHARED_SECRET=change-me-in-production
